<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle"> <!-- 矩形形状 -->
    
    <!-- 背景色：白色 -->
    <solid android:color="#FFFFFF"/>
    
    <!-- 圆角：8dp -->
    <corners android:radius="8dp"/>
    
    <!-- 边框：1dp 浅灰色（关键：用 /> 自闭合） -->
    <stroke
        android:width="1dp"
        android:color="#EEEEEE"/>
        
</shape>