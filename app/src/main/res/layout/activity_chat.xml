<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- 主内容区：聊天界面 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 状态栏占位 -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="15dp" />

        <!-- 标题栏 - 优化图标和添加模型切换 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#65838383"
            android:gravity="center_vertical">

            <!-- 左侧菜单图标 - 增加触摸反馈 -->
            <ImageView
                android:id="@+id/iv_menu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="菜单"
                android:foreground="?attr/selectableItemBackground"
                app:tint="#000000"
                tools:srcCompat="@drawable/ic_menu" />

            <!-- 标题区域 - 可点击切换模型 -->
            <LinearLayout
                android:id="@+id/ll_title_container"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tv_session_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AlinOs 聊天"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_model_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPT-3.5"
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- 右侧添加按钮 -->
            <ImageView
                android:id="@+id/iv_menu_add"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_menu_add"
                android:contentDescription="新建会话"
                android:foreground="?attr/selectableItemBackground"
                app:tint="#000000"
                tools:srcCompat="@drawable/ic_menu_add" />
        </LinearLayout>

        <!-- 聊天记录列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"/>

        <!-- ===================== 新增：动态按钮容器 ===================== -->
        <LinearLayout
            android:id="@+id/ll_dynamic_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#ffffff"
            android:gravity="center_vertical"
            android:visibility="gone">
            <!-- 这里用于代码动态添加按钮，默认隐藏，有按钮时显示 -->
        </LinearLayout>
        <!-- ============================================================ -->

        <!-- 输入区域 - 修复软键盘弹出问题 -->
        <LinearLayout
            android:id="@+id/input_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#f5f5f5">

            <EditText
                android:id="@+id/et_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="请输入消息..."
                android:padding="8dp"
                android:background="@drawable/shape_edittext"
                android:minHeight="48dp"
                android:imeOptions="actionSend"
                android:inputType="textMultiLine"/>

            <Button
                android:id="@+id/btn_send"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="发送"
                android:background="#000000"
                android:textColor="#ffffff"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 侧边栏：会话列表 -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#ffffff"
        android:orientation="vertical">

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#f5f5f5"
            android:gravity="center"
            android:text="会话列表"
            android:textColor="#000000"
            android:textSize="18sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_session_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>