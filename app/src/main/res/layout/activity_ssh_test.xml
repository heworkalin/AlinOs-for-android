<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_ssh_header"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#2D8CF0">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingLeft="14dp"
            android:text="SSH配置"
            android:textColor="#FFFFFF"
            android:textSize="15sp"/>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_ssh_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/cv_ssh_header"
        android:layout_above="@id/fab_add"
        android:paddingTop="12dp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:contentDescription="添加SSH配置"
        app:srcCompat="@android:drawable/ic_input_add"
        app:backgroundTint="#2D8CF0"
        app:tint="#FFFFFF"
        app:fabSize="normal"/>
</RelativeLayout>
