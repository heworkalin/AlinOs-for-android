<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/ll_tool_call"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="start"
        android:maxWidth="280dp"
        android:minWidth="200dp"
        android:background="@drawable/card_background"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true">

        <!-- 摘要行：工具名 + 结果预览 + 耗时 + 状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_tool_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔧 get_weather()"
                    android:textSize="14sp"
                    android:textColor="#333333"/>

                <TextView
                    android:id="@+id/tv_tool_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_tool_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.2s"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginRight="6dp"/>

            <TextView
                android:id="@+id/tv_tool_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- 展开后的详情区域（默认隐藏） -->
        <LinearLayout
            android:id="@+id/ll_tool_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="6dp"
            android:paddingTop="6dp"
            android:background="#1A000000">

            <TextView
                android:id="@+id/tv_tool_request"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#555555"
                android:fontFamily="monospace"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/tv_tool_dividier"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33000000"
                android:layout_marginVertical="4dp"/>

            <TextView
                android:id="@+id/tv_tool_response"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#555555"
                android:fontFamily="monospace"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/tv_tool_divider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33000000"
                android:layout_marginVertical="4dp"/>

            <TextView
                android:id="@+id/tv_tool_log"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#999999"
                android:fontFamily="monospace"
                android:padding="4dp"/>
        </LinearLayout>

        <!-- 展开/折叠指示 -->
        <TextView
            android:id="@+id/tv_expand_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="── 点击展开完整详情 ──"
            android:textSize="11sp"
            android:textColor="#bbbbbb"
            android:layout_marginTop="4dp"
            android:layout_gravity="center"/>
    </LinearLayout>

</LinearLayout>
